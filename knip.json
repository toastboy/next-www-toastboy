{
    "$schema": "./node_modules/knip/schema.json",
    "entry": [
        "prisma/seed.ci.ts",
        "src/tests/**/*.ts",
        "src/tests/**/*.tsx",
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/loading.tsx",
        "src/app/**/error.tsx",
        "src/app/**/global-error.tsx",
        "src/app/**/not-found.tsx",
        "src/app/**/route.ts",
        "vitest.*.config.ts",
        "vitest.setup.*.ts"
    ],
    "project": [
        "src/**/*.{ts,tsx}",
        "prisma/**/*.ts",
        "e2e/**/*.ts",
        ".storybook/**/*.{ts,tsx}",
        "vitest.*.config.ts",
        "vitest.setup.*.ts"
    ],
    "ignoreDependencies": [
        "mariadb",
        "@eslint/config-array",
        "@eslint/object-schema",
        "@next/eslint-plugin-next",
        "@playwright/browser-chromium",
        "@playwright/browser-firefox",
        "@playwright/browser-webkit"
    ],
    "ignoreBinaries": [
        "stdbuf",
        "chromatic"
    ]
}
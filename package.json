{
    "name": "next-www-toastboy",
    "private": true,
    "scripts": {
        "build:storybook": "storybook build",
        "build": "npm run generate && DEBUG=app:* next build",
        "clean": "rm -rf .next",
        "crawllivesite": "npx ts-node -r tsconfig-paths/register --project tsconfig.scripts.json --compiler-options '{\"module\":\"CommonJS\"}' src/lib/crawllivesite/crawllivesite.ts",
        "deepclean": "rm -rf .next node_modules package-lock.json storybook-static build-storybook.log coverage test-results playwright-report && npm cache clean --force",
        "deps:check": "ncu",
        "deps:update": "ncu -u && npm install",
        "dev": "npm run generate && docker compose up -d && next dev",
        "generate": "prisma generate",
        "seed:ci": "npx tsx --tsconfig tsconfig.scripts.json -r tsconfig-paths/register prisma/seed.ci.ts",
        "seed:playwright": "DOTENV_CONFIG_PATH=.env.playwright npx tsx --tsconfig tsconfig.scripts.json -r tsconfig-paths/register prisma/seed.ci.ts",
        "setup:playwright": "npm run generate && DOTENV_CONFIG_PATH=.env.playwright npx prisma db push",
        "check-build": "node -e \"const fs=require('fs'),{execSync}=require('child_process');try{const b=fs.readFileSync('.next/BUILD_ID','utf8').trim(),h=execSync('git rev-parse HEAD').toString().trim();if(b!==h){console.error('Stale build ('+b.slice(0,8)+'), HEAD is '+h.slice(0,8)+'. Run: npm run build');process.exit(1);}}catch{console.error('No build found. Run: npm run build');process.exit(1);}\"",
        "start:playwright": "npm run check-build && PLAYWRIGHT_TEST=true SITE_URL=http://localhost:3002 next start --hostname 127.0.0.1 --port 3002",
        "importlivedb": "TS_NODE_PROJECT=tsconfig.scripts.json TSX_TSCONFIG=tsconfig.scripts.json tsx -r tsconfig-paths/register src/lib/importlivedb/importlivedb.ts",
        "lint:fix": "eslint . --fix",
        "lint": "eslint .",
        "migrate": "prisma migrate dev",
        "start:ci": "PLAYWRIGHT_TEST=true next start --hostname 127.0.0.1 --port 3000",
        "start": "docker compose up -d && next start",
        "stop": "docker compose down",
        "storybook": "storybook dev -p 6006",
        "test:actions:coverage": "vitest run --config vitest.actions.config.ts --coverage",
        "test:actions": "vitest run --config vitest.actions.config.ts",
        "test:api:coverage": "vitest run --config vitest.api.config.ts --coverage",
        "test:api": "vitest run --config vitest.api.config.ts",
        "test:chromatic": "npx chromatic",
        "test:components:coverage": "vitest run --config vitest.components.config.ts --coverage",
        "test:components": "vitest run --config vitest.components.config.ts",
        "test:picker:integration": "vitest run --config vitest.picker.integration.config.ts",
        "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
        "test:lib:coverage": "vitest run --config vitest.lib.config.ts --coverage",
        "test:lib": "vitest run --config vitest.lib.config.ts",
        "test:pages:coverage": "vitest run --config vitest.pages.config.ts --coverage",
        "test:pages": "vitest run --config vitest.pages.config.ts",
        "test:services:coverage": "vitest run --config vitest.services.config.ts --coverage",
        "test:services": "vitest run --config vitest.services.config.ts",
        "test:storybook": "vitest run",
        "test:watch": "vitest --config vitest.unit.config.ts",
        "test": "vitest run --config vitest.unit.config.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@azure/identity": "^4.13.1",
        "@azure/storage-blob": "^12.31.0",
        "@eslint/eslintrc": "^3.3.5",
        "@mantine/code-highlight": "^9.3.0",

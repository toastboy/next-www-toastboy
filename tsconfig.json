{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "incremental": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "target": "es2022",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "prisma/*": [
                "./prisma/*"
            ],
            "*": [
                "./src/*"
            ]
        },
        "plugins": [
            {
                "name": "next"
            }
        ],
        "resolveJsonModule": true,
        "sourceMap": true,
        "strictNullChecks": true,
        "types": [
            "node",
            "vitest/globals",
            "@testing-library/jest-dom"
        ]
    },
    "exclude": [
        ".eslintrc.js",
        ".next",
        "node_modules",
        "www-toastboy"
    ],
    "include": [
        ".next/types/**/*.ts",
        "**/*.js",
        "**/*.ts",
        "**/*.tsx",
        "next-env.d.ts",
        "next.config.mjs"
    ]
}